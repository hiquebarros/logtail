{
  "name": "logtail-api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "build": "tsc -p tsconfig.json",
    "test": "set DATABASE_URL=postgresql://logtail:logtail@localhost:5432/logtail&& tsx --test src/**/*.test.ts",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "start:ingestion": "node dist/ingestion-server.js",
    "dev:ingestion": "tsx watch src/ingestion-server.ts",
    "worker:ingestion": "node dist/workers/ingestion.worker.js",
    "worker:ingestion:dev": "tsx watch src/workers/ingestion.worker.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.58.0",
    "fastify": "^5.2.1",
    "ioredis": "^5.8.1",
    "nodemailer": "^8.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^7.0.11",
    "prisma": "^6.19.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
