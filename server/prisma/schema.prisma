generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(255)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  users        User[]
  members      OrganizationMember[]
  applications Application[]
  logs         Log[]

  @@map("organizations")
}

model User {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?              @map("organization_id") @db.Uuid
  email          String               @unique @db.VarChar(255)
  password       String?              @db.VarChar(255)
  name           String?              @db.VarChar(255)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  organization   Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    OrganizationMember[]

  @@index([organizationId])
  @@map("users")
}

enum OrganizationMemberRole {
  owner
  admin
  member
  viewer
}

enum OrganizationMemberStatus {
  active
  invited
  suspended
}

enum ApplicationLanguage {
  JS
  PHP
  GO
  PYTHON
  OTHER
}

model OrganizationMember {
  id             String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  userId         String                   @map("user_id") @db.Uuid
  role           OrganizationMemberRole   @default(member)
  status         OrganizationMemberStatus @default(active)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model Application {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String       @db.VarChar(255)
  language       ApplicationLanguage @default(OTHER)
  apiKey         String       @unique @map("api_key") @db.VarChar(255)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           Log[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("applications")
}

model Log {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  applicationId  String       @map("application_id") @db.Uuid
  timestamp      DateTime
  level          String       @db.VarChar(32)
  message        String
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  application    Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([timestamp], map: "logs_timestamp_idx")
  @@index([organizationId], map: "logs_organization_id_idx")
  @@index([applicationId], map: "logs_application_id_idx")
  @@index([organizationId, timestamp], map: "logs_organization_timestamp_idx")
  @@index([applicationId, timestamp], map: "logs_application_timestamp_idx")
  @@index([organizationId, applicationId, timestamp, id], map: "logs_org_app_timestamp_id_idx")
  @@index([organizationId, applicationId, level, timestamp], map: "logs_org_app_level_timestamp_idx")
  @@map("logs")
}
